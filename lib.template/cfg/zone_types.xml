<?xml version="1.0" encoding="koi8-r"?>
<!--
    Zone type registry (issue.ztypes-migrate).

    Each <type> entry is one zone category. The vnum attribute is the integer
    referenced by zone.type in lib/world/zon/*.zon files; reordering or
    renumbering a vnum changes the zone classification of every zone using it,
    so DO NOT renumber existing vnums. Add new types with a fresh vnum at the
    end (the legacy ztypes.lst had the same "append-only" rule, baked in here
    by the explicit vnum= attribute rather than file position).

    text_id is a stable C++-style identifier for documentation and OLC use.
    name is the display label shown in `stat zone` and the zedit menu.
    <ingredients val="..."/> (optional) is a "|"-separated list of integer
    ingredient type ids consumed by im.cpp's ImForageRoom; an absent or empty
    list means no forageable ingredients in zones of this type.

    Reload at runtime via `reload ztypes`.
-->
<zone_types>
    <type text_id="kNone"         vnum="0"  name="Ингридиентов нет"/>
    <type text_id="kTown"         vnum="1"  name="Город">
        <ingredients val="16|103|104"/>
    </type>
    <type text_id="kLightForest"  vnum="2"  name="Светлый лес">
        <ingredients val="0|2|11|12|17|104"/>
    </type>
    <type text_id="kDarkForest"   vnum="3"  name="Темный лес">
        <ingredients val="2|6|11|12|17|51|52|104"/>
    </type>
    <type text_id="kFields"       vnum="4"  name="Поля">
        <ingredients val="15|16|104"/>
    </type>
    <type text_id="kMountains"    vnum="5"  name="Горы">
        <ingredients val="101|102"/>
    </type>
    <type text_id="kRivers"       vnum="6"  name="Реки">
        <ingredients val="104"/>
    </type>
    <type text_id="kHouse"        vnum="7"  name="Дом">
