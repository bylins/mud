<?xml version="1.0" encoding="koi8-r"?>
<!-- файл описания стражников (city_guards)
     <guards wars="N"> - глобальный максимум войн, которые клан может вести без агра стражников (0 = не агрить)
     <guard/> - описание стражника:
       vnum="VNUM"            - VNUM моба-стражника (обязательно)
       wars="N"               - макс. число войн, перекрывает глобальное значение
       killer="yes|no"        - агрить ли на душегубов (по умолчанию yes)
       agressor="yes|no|list" - агрить всех агрессоров / не агрить / агрить агрессоров из зон списка (по умолчанию no)
       <zone vnum="VNUM"/>    - VNUM зоны для режима agressor="list"
     В репозитории - только пример; полный боевой файл живёт отдельно.
-->
<guards wars="2">
    <guard vnum="4054" wars="3" killer="yes" agressor="list">
        <zone vnum="41"/>
        <zone vnum="42"/>
    </guard>
</guards>
