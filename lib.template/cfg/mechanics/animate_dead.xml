<!-- issue.animate-dead: warlock construct (animate-dead) parameters. Loaded via CfgManager
     as 'animate_dead'; reload live with `reload animatedead`. See the design in
     claude_1/OUTPUT. Stat scaling is per-creature off the cast competence C (skill_coeff +
     stat_coeff of kAnimateDead's potency_roll). 'luck' is omitted: mobs have no luck stat. -->
<animate_dead>
	<!-- headcount budget = min(<skill>, budget_cap) - sum of held-undead weights -->
	<control skill="kDarkMagic" budget_cap="75" />

	<creature vnum="0" id="kSkeleton" proto_vnum="3001" weight="12">
		<cost corpse_max_level="5" min_rating="0" />
		<scaling>
			<hp          beta="0.25" mode="mult" />
			<damage_dice beta="1.5"  mode="add"  cap="100" />
			<hitroll     beta="0"    mode="add" />
			<ac          beta="0"    mode="add" />        <!-- lower AC = better; add a cap= to bound -->
			<skills      beta="0"    mode="add"  cap="200" />
			<saving      beta="0"    mode="add" />        <!-- all 4 saves; lower = better -->
			<armor       beta="0"    mode="add" />
			<morale      beta="0"    mode="add" />
			<initiative  beta="0"    mode="add" />
		</scaling>
