#include "engine/core/conf.h"
#include "administration/privilege.h"
#include "engine/core/sysdep.h"
#include "engine/core/comm.h"
#include "engine/entities/char_data.h"
#include "engine/structs/structs.h"
#include "utils/logger.h"

const char* REVISION = "$ Build revision: ${REVISION} $";
const char* revision = "${REVISION}";
// issue.versioning: explicit engine identity. engine_version is major.minor.patch.release,
// where major.minor.patch come from the repo-root VERSION file and release = total commit
// count (see tools/meson/generate_version.py). "revision" above stays the short build hash.
const char* engine_name = "${ENGINE_NAME}";
const char* engine_version = "${ENGINE_VERSION}";
const char* build_datetime = "${BUILD_DATETIME}";
const char* build_compiler = "${BUILD_COMPILER}";
const char* build_features = "${BUILD_FEATURES}";

void ShowBuildInfo(CharData *ch) {
  SendMsgToChar(ch, "%s %s, build from %s, revision %s\n", engine_name, engine_version, build_datetime, revision);
  SendMsgToChar(ch, "Based on CircleMUD, version 3.00 beta patchlevel 16\n");
  if (privilege::IsImmortal(ch)) {
    SendMsgToChar(ch, "Compiler: %s\nEnabled features: %s\n", build_compiler, build_features);
  }
}

void LogBuildInfo() {
  log("%s %s, build from %s, revision: %s\r\nCompiler: %s\r\nEnabled features: %s",
      engine_name, engine_version, build_datetime, revision, build_compiler, build_features);
}

