<?xml version="1.0" encoding="koi8-r"?>
<!--
    issue.affect-migration: the room-affect registry. id = the room_spells::ERoomAffect enumerator
    (the identity, kept in C++). Parallels cfg/affects.xml for character affects. Per-room-affect
    display/lifecycle text lives in cfg/messages/ru/room_affect_msg.xml. This file is the scaffold for
    future per-room-affect data (handlers/actions, so a room affect can self-process instead of
    being identified only by its casting spell).
-->
<room_affects>
	<room_affect id="kNoPortalExit"/>
	<room_affect id="kForbidden" flags="kAfUpdateDuration|kAfUpdateMod|kAfDispellable"/>
	<room_affect id="kMeteorStorm" flags="kAfDispellable|kAfMustBeHandled" tick_spell="kThunderStone"/>
	<room_affect id="kRoomLight" flags="kAfUpdateDuration|kAfAccumulateDuration"/>
	<room_affect id="kDeadlyFog" flags="kAfDispellable|kAfMustBeHandled">
		<actions>
			<action target="kTarFoes">
				<area><targets max="-1" /><distribution type="kUniform" /></area>
				<side_spell id="kAcidArrow" />
			</action>
			<action target="kTarFoes">
				<area><targets max="-1" /><distribution type="kUniform" /></area>
				<side_spell id="kPoison" />
			</action>
			<action target="kTarFoes">
				<area><targets max="-1" /><distribution type="kUniform" /></area>
				<side_spell id="kDamageCritic" />
			</action>
			<action target="kTarFoes">
				<area><targets max="-1" /><distribution type="kUniform" /></area>
				<side_spell id="kSacrifice" />
			</action>
		</actions>
	</room_affect>
	<room_affect id="kThunderstorm" flags="kAfDispellable|kAfMustBeHandled" tick_handler="HandleThunderstormTick"/>
	<room_affect id="kRuneLabel" flags="kAfUpdateDuration|kAfUnique"/>
	<room_affect id="kHypnoticPattern" flags="kAfDispellable"/>
	<room_affect id="kBlackTentacles" flags="kAfDispellable|kAfMustBeHandled" tick_spell="kDamageSerious"/>
	<room_affect id="kPortalTimer"/>
</room_affects>
