<?xml version="1.0" encoding="koi8-r"?>
<!--
    Intensity-grade vocabulary for CastToPoints narration (issue.mag-points).
    Each <heal>/<moves>/<thirst>/<cond> section carries an <improve> list of
    <grade percent= text=/> rows; the lookup picks the highest tier whose
    threshold the computed intensity strictly exceeds. text= may carry act()
    suffix codes -- $h (soft-stem instrumental, "–ø–æ—Å–≤–µ–∂–µ–≤—à–∏–º/–ø–æ—Å–≤–µ–∂–µ–≤—à–µ–π"),
    $r (hard-stem instrumental, "–Ω–æ–≤—ã–º/–Ω–æ–≤–æ–π") -- which resolve against the
    target's gender at send time.

    <degrade> sections are parsed but currently empty; CastToPoints will skip
    intensity substitution when the percent is negative until designers fill
    them in.

    Percent thresholds use strict ">" comparison (top-down). A 50% restore
    matches the >25 row, not the >50 row.
-->
<points_intensity>

    <!-- HEAL: percent = restored HP / max HP * 100. -->
    <heal>
        <improve>
            <grade percent="99" text="–ø–æ–ª–Ω–æ—Å—Ç—å—é –∏—Å—Ü–µ–ª—ë–Ω–Ω$r"/>
            <grade percent="75" text="–∑–Ω–∞—á–∏—Ç–µ–ª—å–Ω–æ –ø–æ—Å–≤–µ–∂–µ–≤—à$h"/>
            <grade percent="50" text="–ø–æ—Å–≤–µ–∂–µ–≤—à$h"/>
            <grade percent="25" text="–Ω–µ–º–Ω–æ–≥–æ –ø–æ—Å–≤–µ–∂–µ–≤—à$h"/>
            <grade percent="0"  text="–µ–¥–≤–∞ –∂–∏–≤–µ–µ"/>
        </improve>
        <degrade>
            <!-- intentionally empty: heal-drain narration TBD -->
        </degrade>
    </heal>

    <!-- MOVES: percent = restored moves / max moves * 100. -->
    <moves>
        <improve>
            <grade percent="99" text="–ø–æ–ª–Ω–æ—Å—Ç—å—é –æ—Ç–¥–æ—Ö–Ω—É–≤—à$h"/>
            <grade percent="75" text="–∫—Ä–µ–ø–∫–æ –æ—Ç–¥–æ—Ö–Ω—É–≤—à$h"/>
            <grade percent="50" text="–æ—Ç–¥–æ—Ö–Ω—É–≤—à$h"/>
            <grade percent="25" text="–Ω–µ–º–Ω–æ–≥–æ –æ—Ç–¥–æ—Ö–Ω—É–≤—à$h"/>
            <grade percent="0"  text="–µ–¥–≤–∞ —Å–≤–µ–∂–µ–µ"/>
        </improve>
        <degrade>
            <!-- intentionally empty: drain narration TBD -->
        </degrade>
    </moves>

    <!-- THIRST: percent = removed thirst / current thirst * 100.
         (Engine field is inverted; CastToPoints negates before gain_condition.) -->
    <thirst>
        <improve>
            <grade percent="99" text="–Ω–∞–ø–æ—ë–Ω–Ω$r –¥–æ –∫—Ä–∞—ë–≤"/>
            <grade percent="75" text="—Ö–æ—Ä–æ—à–æ –Ω–∞–ø–∏–≤—à$h—Å—è"/>
            <grade percent="50" text="–Ω–∞–ø–∏–≤—à$h—Å—è"/>
            <grade percent="25" text="–Ω–µ–º–Ω–æ–≥–æ —É—Ç–æ–ª–∏–≤—à$h –∂–∞–∂–¥—É"/>
            <grade percent="0"  text="–µ–¥–≤–∞ –º–µ–Ω–µ–µ –∂–∞–∂–¥—É—â$h"/>
        </improve>
        <degrade>
            <!-- intentionally empty: hungering / thirsting curses TBD -->
        </degrade>
    </thirst>

    <!-- COND (hunger): percent = removed FULL / current FULL * 100. -->
    <cond>
        <improve>
            <grade percent="99" text="–Ω–∞–µ–≤—à$h—Å—è –¥–æ –æ—Ç–≤–∞–ª–∞"/>
            <grade percent="75" text="–∫—Ä–µ–ø–∫–æ –Ω–∞–µ–≤—à$h—Å—è"/>
            <grade percent="50" text="—Å—ã—Ç$r"/>
            <grade percent="25" text="–Ω–µ–º–Ω–æ–≥–æ —É—Ç–æ–ª–∏–≤—à$h –≥–æ–ª–æ–¥"/>
            <grade percent="0"  text="–µ–¥–≤–∞ –º–µ–Ω–µ–µ –≥–æ–ª–æ–¥–Ω$r"/>
        </improve>
        <degrade>
            <!-- intentionally empty -->
        </degrade>
    </cond>

</points_intensity>
