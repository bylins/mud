<?xml version="1.0" encoding="koi8-r"?>
<!--
    Intensity-grade vocabulary for CastToPoints narration (issue.mag-points).
    Each <heal>/<moves>/<thirst>/<cond> section carries an <improve> list of
    <grade percent= text=/> rows; the lookup picks the highest tier whose
    threshold the computed intensity strictly exceeds. text= may carry act()
    suffix codes - $h (soft-stem instrumental, "–њ–Њ—Б–≤–µ–ґ–µ–≤—И–Є–Љ/–њ–Њ—Б–≤–µ–ґ–µ–≤—И–µ–є"),
    $r (hard-stem instrumental, "–љ–Њ–≤—Л–Љ/–љ–Њ–≤–Њ–є") - which resolve against the
    target's gender at send time.

    <degrade> sections are parsed but currently empty; CastToPoints will skip
    intensity substitution when the percent is negative until designers fill
    them in.

    Percent thresholds use strict ">" comparison (top-down). A 50% restore
    matches the >25 row, not the >50 row.
-->
<points_intensity>

    <!-- HEAL: percent = restored HP / max HP * 100. -->
    <heal>
        <improve>
            <grade percent="99" text="–њ–Њ–ї–љ–Њ—Б—В—М—О –Є—Б—Ж–µ–ї—С–љ–љ$r"/>
            <grade percent="75" text="–њ–Њ—З—В–Є –Є—Б—Ж–µ–ї–µ–љ–љ$r"/>
            <grade percent="55" text="–љ–∞–Љ–љ–Њ–≥–Њ –Ј–і–Њ—А–Њ–≤–µ–є"/>
            <grade percent="55" text="–Ј–љ–∞—З–Є—В–µ–ї—М–љ–Њ –ї—Г—З—И–µ"/>
            <grade percent="50" text="–љ–∞–Љ–љ–Њ–≥–Њ –ї—Г—З—И–µ"/>
            <grade percent="35" text="–ї—Г—З—И–µ"/>
            <grade percent="25" text="–љ–µ–Љ–љ–Њ–≥–Њ –ї—Г—З—И–µ"/>
            <grade percent="15" text="—З—Г—В–Њ—З–Ї—Г –ї—Г—З—И–µ"/>
            <grade percent="5"  text="–µ–і–≤–∞ –ґ–Є–≤–µ–µ"/>
        </improve>
        <degrade>
            <!-- intentionally empty: heal-drain narration TBD -->
        </degrade>
    </heal>

    <!-- MOVES: percent = restored moves / max moves * 100. -->
    <moves>
        <improve>
            <grade percent="99" text="–њ–Њ–ї–љ–Њ—Б—В—М—О –Њ—В–і–Њ—Е–љ—Г–≤—И$h"/>
            <grade percent="75" text="–Ї—А–µ–њ–Ї–Њ –Њ—В–і–Њ—Е–љ—Г–≤—И$h"/>
            <grade percent="50" text="–Њ—В–і–Њ—Е–љ—Г–≤—И$h"/>
            <grade percent="25" text="–љ–µ–Љ–љ–Њ–≥–Њ –Њ—В–і–Њ—Е–љ—Г–≤—И$h"/>
            <grade percent="0"  text="–µ–і–≤–∞ —Б–≤–µ–ґ–µ–µ"/>
        </improve>
        <degrade>
            <grade percent="20" text="–њ–Њ–ї–љ–Њ—Б—В—М—О –Є—Б—В–Њ—Й–µ–љ–љ$h"/>
            <grade percent="40" text="—Б–Є–ї—М–љ–Њ —Г—Б—В–∞–≤—И$h"/>
            <grade percent="60" text="—Г—Б—В–∞–≤—И$h"/>
            <grade percent="80" text="–љ–µ–Љ–љ–Њ–≥–Њ —Г—Б—В–∞–≤—И$h"/>
            <grade percent="99"  text="—Б–ї–µ–≥—И–Ї–∞ —Г—Б—В–∞–≤—И$h"/>
        </degrade>
    </moves>

    <!-- THIRST: percent = removed thirst / current thirst * 100.
         (Engine field is inverted; CastToPoints negates before gain_condition.) -->
    <thirst>
        <improve>
            <grade percent="99" text="–њ–Њ–ї–љ–Њ—Б—В—М—О —Г—В–Њ–ї–Є–≤—И$h –ґ–∞–ґ–і—Г"/>
            <grade percent="75" text="—Е–Њ—А–Њ—И–Њ –љ–∞–њ–Є–≤—И$h—Б—П"/>
            <grade percent="50" text="–љ–∞–њ–Є–≤—И$h—Б—П"/>
            <grade percent="25" text="–љ–µ–Љ–љ–Њ–≥–Њ —Г—В–Њ–ї–Є–≤—И$h –ґ–∞–ґ–і—Г"/>
            <grade percent="0"  text="–µ–і–≤–∞ –Љ–µ–љ–µ–µ –ґ–∞–ґ–і—Г—Й$h"/>
        </improve>
        <degrade>
            <grade percent="10" text="–њ–Њ–ї–љ–Њ—Б—В—М –Є—Б—Б—Г—И–µ–љ–љ$x"/>
            <grade percent="30" text="–Є—Б—Б—Г—И–µ–љ–љ$x"/>
            <grade percent="60" text="–ґ–∞–ґ–і—Г—Й$h"/>
            <grade percent="80" text="–ґ–µ–ї–∞—О—Й$h –њ–Є—В—М"/>
            <grade percent="99"  text="—Б–ї–µ–≥–Ї–∞ –ґ–µ–ї–∞—О—Й$h –њ–Є—В—М"/>
        </degrade>
    </thirst>

    <!-- COND (hunger): percent = removed FULL / current FULL * 100. -->
    <cond>
        <improve>
            <grade percent="99" text="–љ–∞–µ–≤—И$h—Б—П –і–Њ –Њ—В–≤–∞–ї–∞"/>
            <grade percent="75" text="–Ї—А–µ–њ–Ї–Њ –љ–∞–µ–≤—И$h—Б—П"/>
            <grade percent="50" text="—Б—Л—В$r"/>
            <grade percent="25" text="–љ–µ–Љ–љ–Њ–≥–Њ —Г—В–Њ–ї–Є–≤—И$h –≥–Њ–ї–Њ–і"/>
            <grade percent="0"  text="–µ–і–≤–∞ –Љ–µ–љ–µ–µ –≥–Њ–ї–Њ–і–љ$r"/>
        </improve>
        <degrade>
            <grade percent="10" text="—Г–Љ–Є—А–∞—О—Й$h —Б –≥–Њ–ї–Њ–і—Г"/>
            <grade percent="30" text="–Є–Ј–≥–Њ–ї–Њ–і–∞–≤—И$h—Б—П"/>
            <grade percent="60" text="—Б–Є–ї—М–љ–Њ –≥–Њ–ї–Њ–і$r"/>
            <grade percent="80" text="–≥–Њ–ї–Њ–і–љ$r"/>
            <grade percent="99"  text="–ґ–µ–ї–∞—О—Й$h –њ–µ—А–µ–Ї—Г—Б–Є—В—М"/>
        </degrade>
    </cond>

    <!-- DAMAGE (issue.mag-points step 2): substituted into the {intensity}
         placeholder on kFightHit* messages by SendCombatMessages in
         skills.cpp. Percentage formula = damage * 100 / STRIKER's max HP -
         a "% of MY power" scale, uniform for all viewers in the room. The
         mid range (>10) is intentionally an empty string so a normal hit
         reads as "–Т—Л —Г–і–∞—А–Є–ї–Є $N3." with no adverb. The >150 tier crosses
         the lethal threshold. Each text carries a TRAILING SPACE because
         the placeholder sits directly before the verb ("–Т—Л {intensity}-
         —Г–і–∞—А–Є–ї–Є $N3"), so an empty tier collapses cleanly. -->
    <damage>
        <improve>
            <grade percent="150" text="–°–Ь–Х–†–Ґ–Х–Ы–ђ–Э–Ю "/>
            <grade percent="130" text="–£–С–Ш–Щ–°–Ґ–Т–Х–Э–Э–Ю "/>
            <grade percent="110" text="–£–Ц–Р–°–Э–Ю "/>
            <grade percent="99" text="–Ц–Х–°–Ґ–Ю–Ъ–Ю "/>
            <grade percent="95" text="–Э–Х–Т–Ђ–Э–Ю–°–Ш–Ь–Ю –С–Ю–Ы–ђ–Э–Ю "/>
            <grade percent="90" text="–І–†–Х–Ч–Т–Т–І–Р–Щ–Э–Ю –С–Ю–Ы–ђ–Э–Ю "/>
            <grade percent="85" text="–Ю–І–Х–Э–ђ –С–Ю–Ы–ђ–Э–Ю "/>
            <grade percent="80" text="–С–Ю–Ы–ђ–Э–Ю "/>
            <grade percent="75" text="—З—А–µ–Ј–≤—Л—З–∞–є–љ–Њ —Б–Є–ї—М–љ–Њ "/>
            <grade percent="70" text="–Њ—З–µ–љ—М —Б–Є–ї—М–љ–Њ "/>
            <grade percent="65" text="—Б–Є–ї—М–љ–Њ "/>
            <grade percent="60" text="–Њ—Б–љ–Њ–≤–∞—В–µ–ї—М–љ–Њ "/>
            <grade percent="55" text="–Њ—З–µ–љ—М –Ї—А–µ–њ–Ї–Њ "/>
            <grade percent="50" text="–Ї—А–µ–њ–Ї–Њ "/>
            <grade percent="40" text=""/>
            <grade percent="35" text="–љ–µ–Ј–љ–∞—З–Є—В–µ–ї—М–љ–Њ"/>
            <grade percent="30" text="—Б–ї–∞–±–Њ "/>
            <grade percent="25" text="–Њ—З–µ–љ—М —Б–ї–∞–±–Њ "/>
            <grade percent="20" text="—Б–ї–µ–≥–Ї–∞ "/>
            <grade percent="15" text="–ї–µ–≥–Њ–љ—М–Ї–Њ "/>
            <grade percent="10" text="—Б–ї–∞–±–µ–љ—М–Ї–Њ "/>
            <grade percent="5" text="–µ–і–≤–∞-–µ–і–≤–∞ "/>
        </improve>
        <degrade>
            <!-- damage doesn't go negative; left empty for symmetry -->
        </degrade>
    </damage>

</points_intensity>
