<?xml version="1.0" encoding="KOI8-R"?>
<!--
	Зоны, в которых не работает игровая добыча.

	Два раздела, и это разные вещи:

	  <service> -- служебные зоны. Системные, тестовые, склады образцов для крафта,
	               витрины минисетов. Игрок туда обычным путем не попадает.
	               Исторически это 1-39; когда номера кончились, добавили 2000-2030.

	  <starting> -- начальные зоны (40-99). Настоящие зоны для новичков, просто сеты
	                в них не падают.

	Внутри раздела зона задается либо целиком:   <zone vnum="2005"/>
	либо диапазоном (границы включительно):      <zone from="2000" to="2030"/>

	Раньше эти границы были зашиты в коде, причем в каждом месте по-своему. Если
	заводишь новую служебную или начальную зону -- добавляй ее сюда, а не в код.
-->
<service_zones>
	<service>
		<!-- системные, тестовые, склады образцов -->
		<zone from="1" to="39"/>
		<!-- продолжение служебных: номера в первом диапазоне кончились -->
		<zone from="2000" to="2030"/>
	</service>

	<starting>
		<!-- зоны для новичков -->
		<zone from="40" to="99"/>
	</starting>
</service_zones>
