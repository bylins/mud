	<affect id="kFireShield" buff="Y" dispel_mod="-35">
		<flags val="kAfBattledec|kAfUpdateDuration|kAfUpdateMod|kAfDispellable|kAfMaterialize|kAfAegis"/>
		<shield weight="10"/>
		<actions>
			<!-- Retaliation: a physical hit (not ignoring the shield, not a crit) reflects 15% back
			     (+5 NPC bearer, +5 boss). Reflected as kUndefDmg, attributed to the incoming attack.
			     Fires only when fire is the shield chosen for this hit (handled in SelectMagicShield). -->
			<action>
				<trigger val="kWardDamage"/>
				<retaliation>
					<conditions>
						<type val="kPhysDmg"/>
						<flags missing="kIgnoreFireShield|kCritHit"/>
					</conditions>
					<percent min="15" max="15" npc_bonus="5" boss_bonus="5"/>
					<element type="kUndefDmg"/>
				</retaliation>
			</action>
			<!-- Reduction, reflect case (phys, !ignore): silent; the reflected hit is the visible effect.
			     Ordered before the general reduction so kShieldApplied gates the "weakened" message out. -->
			<action>
				<trigger val="kWardDamage"/>
				<damage_change stage="late" msg="none">
					<conditions>
						<type val="kPhysDmg"/>
						<flags missing="kIgnoreFireShield|kCritHit|kShieldApplied"/>
					</conditions>
					<variation min="30" max="50" factor="-1"/>
					<flags add="kDrawBriefFireShield|kShieldApplied"/>
				</damage_change>
			</action>
			<!-- Reduction, non-reflect case (non-phys, or physical it can't reflect): shows "weakened". -->
			<action>
				<trigger val="kWardDamage"/>
				<damage_change stage="late">
					<conditions>
						<flags missing="kCritHit|kShieldApplied"/>
					</conditions>
					<variation min="30" max="50" factor="-1"/>
					<flags add="kDrawBriefFireShield|kShieldApplied"/>
				</damage_change>
			</action>
		</actions>
	</affect>
