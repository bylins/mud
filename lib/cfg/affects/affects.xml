	<!-- issue.damage-over-time: a fully data-driven fire damage-over-time debuff (imposed by kFireBlast).
	     kAfSameTime makes it a combat DoT: battle_affect_update runs its <actions> once per combat round
	     via RunCharAffectTick. The kBattlePulse action deals a self-<damage> tick (default target kTarSame
	     = the bearer) scaled by the affect's stored potency: with a tick's fixed-potency roll competence
	     is 0, so per-tick damage = amount.min + ceil(stored_potency * dices_weight). No C++ handler and no
	     stat <apply> - the damage lives entirely in data. kAfDispellable so it can be removed by dispel. -->
	<affect id="kBurning" buff="N">
		<flags val="kAfSameTime|kAfDispellable"/>
		<actions>
			<!-- target="kTarFightSelf" = the bearer: a lone tick action defaults to kTarSame, which resolves
			     to the PREVIOUS action's targets (empty here) -> no victim -> no damage. kTarFightSelf
			     returns {caster}=the bearer, so the DoT damages the burning char. -->
			<!-- kPulse (not kBattlePulse) so the burn ticks BOTH in combat (battle_affect_update) and out of
			     combat (player_/mobile_affect_update) - e.g. a fire-trap dispel sting on a char who is not
			     fighting. RunCharAffectTick fires kPulse regardless of combat state. -->
			<action target="kTarFightSelf">
				<trigger val="kPulse"/>
				<!-- issue.damage-over-time: per-tick damage = amount.min + ceil(stored_potency * dices_weight).
				     dices_weight is the DAMAGE scale; it is independent of the dispel strength (the stored
				     potency itself, set by kFireBlast's <affects potency_weight>). Raise dices_weight for a
				     harder-hitting burn without making it any harder to dispel. -->
				<damage saving="kNone">
					<amount min="0" beta="0.6" weight="0" />
				</damage>
			</action>
		</actions>
	</affect>
</affects>
