		<shield weight="10"/>
		<actions>
			<!-- Crit-absorb: a crit (not precise-style, not poison) has a 94% chance to be neutralized:
			     reduce 30-50% AND clear kCritHit (converts it to a glancing hit). Its own "crit" flavor. -->
			<action>
				<trigger val="kWardDamage"/>
				<damage_change stage="late" prob="94" msg="crit">
					<conditions>
						<type val="kPhysDmg|kMagicDmg|kPureDmg|kUndefDmg"/>
						<flags present="kCritHit" missing="kPunctualCrit|kShieldApplied"/>
					</conditions>
					<variation min="30" max="50" factor="-1"/>
					<flags remove="kCritHit" add="kShieldApplied"/>
				</damage_change>
			</action>
			<!-- Normal: soften a non-crit hit 30-50%. -->
			<action>
				<trigger val="kWardDamage"/>
				<damage_change stage="late">
					<conditions>
						<flags missing="kCritHit|kShieldApplied"/>
					</conditions>
					<variation min="30" max="50" factor="-1"/>
