	     (defaults to the id token). Example:
	         <gem vnum="900">
	             <apply id="kHpRegen" val="30"/>
	             <affect id="kDetectInvisible"/>
	             <flag id="kNodisarm"/>
	             <skill id="kKick" val="5"/>
