         The appended <action> reuses the same affect/charges machinery as kFireBlast's kBurning. -->
    <feat id="kEmberTouch" mode="kTesting">
        <talent_patches>
            <talent_patch spell="kBurningHands" op="append">
                <action id="EmberIgnite" target="kTarSame">
                    <affects saving="kReflex" resist="kFire" potency_weight="0.5">
                        <duration base="0" skill_divisor="6" min="2" max="6" />
                        <charges max="5"/>
                        <affect id="kBurning"/>
                    </affects>
                </action>
            </talent_patch>
        </talent_patches>
    </feat>
    <!-- issue.perk-action-patching Phase 2: prove (b) manifestation-level <damage> replace (copy-into-
