<?xml version="1.0" encoding="koi8-r"?>
<!--
    issue.specials Phase 2: messages SHARED by the special-procedure dispatch framework.
    kAmbiguous is a prefix; the resolver appends the dynamic tooltip and the newline. kUnknownCommand
    is the resolver's "wrong shop" reply; kNotHere is RunSpecCommand's reply when no carrier is present.
    Per-procedure greetings and texts live in their own files (bank_msg.xml, ...).
-->
<special_msg>
	<msg_sheaf id="kDefault">
		<message type="kAmbiguous" val="Уточните, что именно:"/>
		<message type="kUnknownCommand" val="Вам явно в какое-то другое заведение."/>
		<message type="kNotHere" val="Это нельзя сделать здесь."/>
	</msg_sheaf>
</special_msg>
