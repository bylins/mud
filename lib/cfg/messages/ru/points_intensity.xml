<!--
    Intensity-grade vocabulary for CastToPoints narration (issue.mag-points
    + issue.point-bugs).

    Each <heal>/<moves>/<thirst>/<full> section carries <improve> and
    <degrade> lists of <grade percent= text=/> rows. The lookup picks the
    largest threshold T such that T <= input (walk descending), so both
    directions share a single algorithm and the tier whose threshold the
    input has crossed wins.

    text= may carry act() suffix codes - $h (soft-stem instrumental,
    "–Ω–Ψ―¹–≤–Β–Ε–Β–≤―à–Η–Φ/–Ω–Ψ―¹–≤–Β–Ε–Β–≤―à–Β–Ι"), $r (hard-stem instrumental, "–Ϋ–Ψ–≤―΄–Φ/–Ϋ–Ψ–≤–Ψ–Ι") -
    which resolve against the target's gender at send time.

    Percent conventions:
      heal   improve: amount / max_hp     (positive, 0..100)
      heal   degrade: empty - heal stays positive-only by design
      moves  improve: amount / max_moves  (positive, 0..100)
      moves  degrade: amount / max_moves  (negative, -100..0)
      thirst improve: removed / current   (positive, 0..100)
      thirst degrade: -(cond_after * 100) / kMaxCondition   (negative)
      full   improve: removed / current   (positive, 0..100)
      full   degrade: -(cond_after * 100) / kMaxCondition   (negative)

    For thirst/full DEGRADE the formula uses the AFTER-state of the
    inverted engine field (kMaxCondition = 48): a thirstier/hungrier
    character lands a more-negative percent and matches a more-extreme
    tier. The improve formula keeps its "fraction of current thirst/hunger
    relieved" sense and yields positive percents.
-->
<points_intensity>

    <!-- HEAL: improve % = amount / max_hp; degrade unused (heal stays
         positive-only by design; designers may fill <degrade> if a
         heal-drain spell is ever introduced). -->
    <heal>
        <improve>
            <grade percent="99" text="–Ω–Ψ–Μ–Ϋ–Ψ―¹―²―¨―é –Η―¹―Ü–Β–Μ―ë–Ϋ–Ϋ$r"/>
            <grade percent="75" text="–Ω–Ψ―΅―²–Η –Η―¹―Ü–Β–Μ–Β–Ϋ–Ϋ$r"/>
            <grade percent="55" text="–Ϋ–Α–Φ–Ϋ–Ψ–≥–Ψ –Ζ–¥–Ψ―Ä–Ψ–≤–Β–Ι"/>
            <grade percent="55" text="–Ζ–Ϋ–Α―΅–Η―²–Β–Μ―¨–Ϋ–Ψ –Μ―É―΅―à–Β"/>
            <grade percent="50" text="–Ϋ–Α–Φ–Ϋ–Ψ–≥–Ψ –Μ―É―΅―à–Β"/>
            <grade percent="35" text="–Μ―É―΅―à–Β"/>
            <grade percent="25" text="–Ϋ–Β–Φ–Ϋ–Ψ–≥–Ψ –Μ―É―΅―à–Β"/>
            <grade percent="15" text="―΅―É―²–Ψ―΅–Κ―É –Μ―É―΅―à–Β"/>
            <grade percent="5"  text="–Β–¥–≤–Α –Ε–Η–≤–Β–Β"/>
        </improve>
        <degrade>
            <!-- intentionally empty: heal-drain narration TBD -->
        </degrade>
    </heal>

    <!-- MOVES: improve % = restored / max_moves;
         degrade % = drain / max_moves (negative). -->
    <moves>
        <improve>
            <grade percent="99" text="–Ω–Ψ–Μ–Ϋ–Ψ―¹―²―¨―é –Ψ―²–¥–Ψ―Ö–Ϋ―É–≤―à$h"/>
            <grade percent="75" text="–Κ―Ä–Β–Ω–Κ–Ψ –Ψ―²–¥–Ψ―Ö–Ϋ―É–≤―à$h"/>
            <grade percent="50" text="–Ψ―²–¥–Ψ―Ö–Ϋ―É–≤―à$h"/>
            <grade percent="25" text="–Ϋ–Β–Φ–Ϋ–Ψ–≥–Ψ –Ψ―²–¥–Ψ―Ö–Ϋ―É–≤―à$h"/>
            <grade percent="0"  text="–Β–¥–≤–Α ―¹–≤–Β–Ε–Β–Β"/>
        </improve>
        <degrade>
            <grade percent="-95" text="–Ω–Ψ–Μ–Ϋ–Ψ―¹―²―¨―é –Η―¹―²–Ψ―â–Β–Ϋ–Ϋ$h"/>
            <grade percent="-80" text="―¹–Η–Μ―¨–Ϋ–Ψ ―É―¹―²–Α–≤―à$h"/>
            <grade percent="-60" text="―É―¹―²–Α–≤―à$h"/>
            <grade percent="-40" text="–Ϋ–Β–Φ–Ϋ–Ψ–≥–Ψ ―É―¹―²–Α–≤―à$h"/>
            <grade percent="-20" text="―¹–Μ–Β–≥―à–Κ–Α ―É―¹―²–Α–≤―à$h"/>
        </degrade>
    </moves>

    <!-- THIRST: improve % = removed thirst / current thirst (engine field is
         inverted, CastToPoints negates the talent amount before
         gain_condition). Degrade % = -(thirst_after * 100) / 48 - the
         after-state's saturation on the 0..48 scale, signed negative so a
         thirstier outcome lands a more-negative tier. -->
    <thirst>
        <improve>
            <grade percent="99" text="–Ω–Ψ–Μ–Ϋ–Ψ―¹―²―¨―é ―É―²–Ψ–Μ–Η–≤―à$h –Ε–Α–Ε–¥―É"/>
            <grade percent="75" text="―Ö–Ψ―Ä–Ψ―à–Ψ –Ϋ–Α–Ω–Η–≤―à$h―¹―è"/>
            <grade percent="50" text="–Ϋ–Α–Ω–Η–≤―à$h―¹―è"/>
            <grade percent="25" text="–Ϋ–Β–Φ–Ϋ–Ψ–≥–Ψ ―É―²–Ψ–Μ–Η–≤―à$h –Ε–Α–Ε–¥―É"/>
            <grade percent="0"  text="–Β–¥–≤–Α –Φ–Β–Ϋ–Β–Β –Ε–Α–Ε–¥―É―â$h"/>
        </improve>
        <degrade>
            <grade percent="-95" text="–Ω–Ψ–Μ–Ϋ–Ψ―¹―²―¨―é –Η―¹―¹―É―à–Β–Ϋ–Ϋ$h"/>
            <grade percent="-75" text="–Η―¹―¹―É―à–Β–Ϋ–Ϋ$h"/>
            <grade percent="-55" text="–Ε–Α–Ε–¥―É―â$h –≥–Μ–Ψ―²–Κ–Α –≤–Ψ–¥―΄"/>
            <grade percent="-30" text="–Ε–Β–Μ–Α―é―â$h –Ω–Η―²―¨"/>
            <grade percent="-10" text="―¹–Μ–Β–≥–Κ–Α –Ε–Β–Μ–Α―é―â$h –Ω–Η―²―¨"/>
        </degrade>
    </thirst>

    <!-- FULL (hunger): improve % = removed FULL / current FULL (engine
         field is inverted, CastToPoints negates before gain_condition).
         Degrade % = -(full_after * 100) / 48. Renamed from <cond> in
         issue.point-bugs to free "cond" for the overall triplet name. -->
    <full>
        <improve>
            <grade percent="99" text="–Ϋ–Α–Β–≤―à$h―¹―è –¥–Ψ –Ψ―²–≤–Α–Μ–Α"/>
            <grade percent="75" text="–Κ―Ä–Β–Ω–Κ–Ψ –Ϋ–Α–Β–≤―à$h―¹―è"/>
            <grade percent="50" text="―¹―΄―²$r"/>
            <grade percent="25" text="–Ϋ–Β–Φ–Ϋ–Ψ–≥–Ψ ―É―²–Ψ–Μ–Η–≤―à$h –≥–Ψ–Μ–Ψ–¥"/>
            <grade percent="0"  text="–Β–¥–≤–Α –Φ–Β–Ϋ–Β–Β –≥–Ψ–Μ–Ψ–¥–Ϋ$r"/>
        </improve>
        <degrade>
            <grade percent="-95" text="―É–Φ–Η―Ä–Α―é―â$h ―¹ –≥–Ψ–Μ–Ψ–¥―É"/>
            <grade percent="-75" text="–Η–Ζ–≥–Ψ–Μ–Ψ–¥–Α–≤―à$h―¹―è"/>
            <grade percent="-55" text="―¹–Η–Μ―¨–Ϋ–Ψ –≥–Ψ–Μ–Ψ–¥$r"/>
            <grade percent="-30" text="–≥–Ψ–Μ–Ψ–¥–Ϋ$r"/>
            <grade percent="-10" text="–Ε–Β–Μ–Α―é―â$h –Ω–Β―Ä–Β–Κ―É―¹–Η―²―¨"/>
        </degrade>
    </full>

    <!-- DAMAGE (issue.mag-points step 2): substituted into the {intensity}
         placeholder on kFightHit* messages by SendCombatMessages in
         skills.cpp. Percentage formula = damage * 100 / STRIKER's max HP -
         a "% of MY power" scale, uniform for all viewers in the room. The
         mid range (>10) is intentionally an empty string so a normal hit
         reads as "–£―΄ ―É–¥–Α―Ä–Η–Μ–Η $N3." with no adverb. The >150 tier crosses
         the lethal threshold. Each text carries a TRAILING SPACE because
         the placeholder sits directly before the verb ("–£―΄ {intensity}-
         ―É–¥–Α―Ä–Η–Μ–Η $N3"), so an empty tier collapses cleanly. -->
    <damage>
        <!-- issue.unstable-hotfixes: graded by ABSOLUTE damage (HP), NOT %-of-attacker-HP.
             percent= here is the absolute HP threshold; Resolve picks the largest threshold <= the hit.
             Calibrated weakest ~5 HP ... strongest 1000+ HP. -->
        <improve>
            <grade percent="1050" text="–Γ–€–ï–†–Δ–ï–¦–§–ù–û "/>
            <grade percent="950" text="–Θ–ë–‰–ô–Γ–Δ–£–ï–ù–ù–û "/>
            <grade percent="870" text="–Θ–•–ê–Γ–ù–û "/>
            <grade percent="760" text="–•–ï–Γ–Δ–û–ö–û "/>
            <grade percent="640" text="–ù–ï–£–Ϊ–ù–û–Γ–‰–€–û –ë–û–¦–§–ù–û "/>
            <grade percent="530" text="–ß–†–ï–½–£–£–ß–ê–ô–ù–û –ë–û–¦–§–ù–û "/>
            <grade percent="435" text="–û–ß–ï–ù–§ –ë–û–¦–§–ù–û "/>
            <grade percent="355" text="–ë–û–¦–§–ù–û "/>
            <grade percent="285" text="―΅―Ä–Β–Ζ–≤―΄―΅–Α–Ι–Ϋ–Ψ ―¹–Η–Μ―¨–Ϋ–Ψ "/>
            <grade percent="225" text="–Ψ―΅–Β–Ϋ―¨ ―¹–Η–Μ―¨–Ϋ–Ψ "/>
            <grade percent="175" text="―¹–Η–Μ―¨–Ϋ–Ψ "/>
            <grade percent="135" text="–Ψ―¹–Ϋ–Ψ–≤–Α―²–Β–Μ―¨–Ϋ–Ψ "/>
            <grade percent="105" text="–Ψ―΅–Β–Ϋ―¨ –Κ―Ä–Β–Ω–Κ–Ψ "/>
            <grade percent="80" text="–Κ―Ä–Β–Ω–Κ–Ψ "/>
            <grade percent="60" text=""/>
            <grade percent="45" text="–Ϋ–Β–Ζ–Ϋ–Α―΅–Η―²–Β–Μ―¨–Ϋ–Ψ "/>
            <grade percent="33" text="―¹–Μ–Α–±–Ψ "/>
            <grade percent="24" text="–Ψ―΅–Β–Ϋ―¨ ―¹–Μ–Α–±–Ψ "/>
            <grade percent="17" text="―¹–Μ–Β–≥–Κ–Α "/>
            <grade percent="12" text="–Μ–Β–≥–Ψ–Ϋ―¨–Κ–Ψ "/>
            <grade percent="8" text="―¹–Μ–Α–±–Β–Ϋ―¨–Κ–Ψ "/>
            <grade percent="5" text="–Β–¥–≤–Α-–Β–¥–≤–Α "/>
        </improve>
        <degrade>
            <!-- damage doesn't go negative; left empty for symmetry -->
        </degrade>
    </damage>

</points_intensity>
