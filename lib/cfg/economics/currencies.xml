<?xml version="1.0" encoding="koi8-r"?>
<!--
Формат:
    <currency text_id="kKuna" vnum="0" mode="kEnabled">
        <permits give="1" obj="1" bank="1" transfer="1" transfer_other="1" transfer_tax="5" drop="100" clan_tax="25"/>
        <flags account_shared="N"  locked="Y"/>
    </currency>

  Имя (строка для поиска + склонения по падежам) теперь хранится отдельно, в
  messages/ru/currency_msg.xml (контейнер сообщений валют, грузится до currencies.xml),
  по ключу text_id. Падежи задаются в новом формате <case id="kNom" val="..."/>.

text_id="id для указаня в других конфигах" name="имя для поиска по имени" vnum="виртуальный номер" mode="режим"
gender - Грамматиеский род, Имена в единственном и множественном числе для всех падежей.
permits - флаги допустимых операций
    give- можно передать
    obj - может выпасть в качестве предмета и лежать на земле
    bank - можно вложить в банк
    transfer - можно переводить в пределах аккаунта (не имеет смысла для общей на аккаунт валюты)
    transfer_others - можно переводить на другие аккаунты
    transfer_tax - налог на перевод
    drop - сколько процентов из находящейся на руках валюты будет потеряно при смерти (если obj разрешен - останется в трупе или на земле)
    clan_tax - максимально допустимый клановый налог
flags - флаги
    account_shared - валюта общая для всех персонажей аккаунта
    locked - запрещено изменять через OLC (снять или поставить можно только вручную в файле)

-->
<currencies>
    <currency text_id="kKuna" vnum="0" mode="kEnabled">
        <permits give="1" obj="1" bank="1" transfer="1" transfer_other="1" transfer_tax="5" drop="100" clan_tax="25"/>
        <flags account_shared="N"  locked="Y" logged="Y" msdp="Y" money_stat="Y"/>
    </currency>
