; В этом файле хранятся некоторые переменные некоторых скилов
; (умение "горное дело" вынесено в cfg/mechanics/digging.xml)
;
; ЮВЕЛИР
;
; // Все значения целые
insgem_lag			2	// лаг на вплавление (в коде умножается на PULSE_VIOLENCE)
insgem_minus_for_affect		15	// на сколько уменьшается скилл при проверке за каждый аффект или APPLY_ на шмотке
insgem_prob_divide		1	// на это чило будет делиться скилл в момент проверки, для усложнения вплавки
insgem_dikey_percent		10	// процент уничтожения шмотки при неудачном вплавлении
insgem_timer_plus_percent	10	// на сколько проц. увеличивается таймер у перекованной шмотки при каждом вплавлении
insgem_timer_minus_percent	10	// на сколько проц. уменьшается таймер у шмотки при каждом вплавлении
;
;
